    p1.setY(15);
    p1.display();

    p2.setXY(30, 40);
    p2.display();

    cout << "\n===== Question 4 =====" << endl;
    Box b;
    b.setValue(10, 5);
    cout << "Area = " << b.area() << endl;

    Box3D b3;
    b3.setValue(10, 5, 4);
    cout << "Volume = " << b3.volume() << endl;

    return 0;
}
