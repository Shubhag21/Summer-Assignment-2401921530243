//===================== Question 3 =====================

class Point {
private:
    int x, y;

public:
    Point() {
        x = 0;
        y = 0;
    }

    Point(int x, int y) {
        this->x = x;
        this->y = y;
    }

    void setX(int x) {
        this->x = x;
    }

    void setY(int y) {
        this->y = y;
    }

    void setXY(int x, int y) {
        this->x = x;
        this->y = y;
    }

    void display() {
        cout << "Point = (" << x << ", " << y << ")" << endl;
    }
};

//===================== Question 4 =====================

class Box {
protected:
    int length, breadth;

public:
    Box(int l = 0, int b = 0) {
        length = l;
        breadth = b;
    }

    void setValue(int l, int b) {
        length = l;
        breadth = b;
    }

    int area() {
        return length * breadth;
    }
};

class Box3D : public Box {
private:
    int height;

public:
    Box3D(int l = 0, int b = 0, int h = 0) : Box(l, b) {
        height = h;
    }

    void setValue(int l, int b, int h) {
        length = l;
        breadth = b;
        height = h;
    }

    int volume() {
        return length * breadth * height;
    }
};

