#include <iostream>
using namespace std;

//===================== Question 1 =====================

// Interface
class Test {
public:
    virtual int square(int) = 0;
};

// Arithmetic class implementing Test
class Arithmetic : public Test {
public:
    int square(int x) {
        return x * x;
    }
};

// ToTestInt class
class ToTestInt {
public:
    void display() {
        Arithmetic obj;
        int n;
        cout << "Enter a number: ";
        cin >> n;
        cout << "Square = " << obj.square(n) << endl;
    }
};

